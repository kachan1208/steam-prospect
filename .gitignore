# Analytics data & databases (rebuildable via `task etl`, or read-only source — never committed).
# Anchored to the repo root so nested source dirs like api/app/data/ (seed JSON) stay tracked.
/data/
*.duckdb
prospect_control.db
steam_games.db*
**/steam_games.db*

# Python / Node dependency & virtual env directories
**/.venv
**/node_modules
__pycache__/
*.pyc

# Build output
web/dist

# Env files (secrets / machine-specific overrides)
.env

# Editor / OS cruft
.DS_Store
web/*.tsbuildinfo
*.tsbuildinfo
.claude/
